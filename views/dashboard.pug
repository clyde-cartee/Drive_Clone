extends layout

block content
  mixin folderTree(nodes)
    each folder in nodes
      - const hasChildren = folder.children && folder.children.length > 0
      - const isActive = currentFolder && currentFolder.id === folder.id
      .nav-folder-wrap
        .nav-folder-row(class=isActive ? 'active' : '', data-id=folder.id)
          button.nav-toggle(type='button', class=hasChildren ? '' : 'hidden', data-target='folder-' + folder.id) ›
          a(href='/dashboard?folder=' + folder.id)
            span.nav-icon 📁
            span.nav-folder-name(title=folder.name)= folder.name
          .nav-folder-tooltip= folder.name
        if hasChildren
          .nav-children(id='folder-' + folder.id)
            +folderTree(folder.children)
            

  .shell
    aside.sidebar
      .logo
        span.logo-icon ⬡
        span.logo-text DriveClone
      nav.sidebar-nav
        a.nav-item(href='/dashboard', class=!currentFolder ? 'active' : '')
          span.nav-icon 🏠
          span Home
        .nav-divider My Folders
        if folderTree.length > 0
          +folderTree(folderTree)
        else
          p.nav-empty No folders yet
      .sidebar-user
        span.user-icon 👤
        span= username
        a(href='/logout') Log out

    main.main
      .topbar
        .breadcrumb
          a(href='/dashboard') Home
          each crumb in breadcrumb
            span.crumb-sep ›
            a(href='/dashboard?folder=' + crumb.id)= crumb.name
          if currentFolder
            span.crumb-sep ›
            span.crumb-current= currentFolder.name

        .topbar-right
          //- Search
          .search-wrap
            input#searchInput(type='text', placeholder='Search files and folders…', autocomplete='off')
            .search-results#searchResults

          //- New folder
          form.inline-form(action='/folder/create' + (folderId ? '?folder=' + folderId : ''), method='POST')
            input(type='text', name='name', placeholder='New folder…')
            button(type='submit') + Folder

      .upload-card
        form(action='/upload' + (folderId ? '?folder=' + folderId : ''), method='POST', enctype='multipart/form-data')
          label.upload-zone(for='fileInput')
            span.upload-icon ↑
            span.upload-text Drop a file or click to upload
            input(type='file', name='file', id='fileInput', required)
          .upload-preview(style='display:none')
            img.preview-img(src='', alt='preview', style='display:none')
            span.preview-name
          button.upload-btn(type='submit') Upload

      if folders.length > 0
        .section-label Folders
        .folders-grid
          each folder in folders
            .folder-tile(data-id=folder.id, data-name=folder.name)
              a(href='/dashboard?folder=' + folder.id)
                span.tile-icon 📁
                span.tile-name= folder.name
              form(action='/folder/delete/' + folder.id, method='POST', onsubmit='return confirm("Delete folder?")')
                button.tile-delete(type='submit') ×

      .section-label= currentFolder ? currentFolder.name + ' Files' : 'All Files'
      if files.length === 0
        .empty-state
          span.empty-icon 📭
          p No files here yet
      else
        .files-table
          .files-header
            span Name
            span Type
            span Size
            span Date
            span Actions
          each file in files
            .files-row(data-id=file.id, data-name=file.originalName)
              span.file-name
                a(href='/file/' + file.id, target='_blank')= file.originalName
              span.file-type= file.mimetype.split('/')[1]
              span= (file.size / 1024).toFixed(1) + ' KB'
              span= new Date(file.createdAt).toLocaleDateString()
              .file-actions
                a.btn-view(href='/file/' + file.id, target='_blank') View
                a.btn-dl(href='/download/' + file.id) ↓
                form.move-form(action='/file/move/' + file.id + (folderId ? '?folder=' + folderId : ''), method='POST')
                  select(name='folderId')
                    option(value='null') — Root —
                    each f in allFolders
                      option(value=f.id, selected=file.folderId === f.id)= f.name
                  button(type='submit') Move
                form(action='/delete/' + file.id, method='POST', onsubmit='return confirm("Delete?")')
                  button.btn-del(type='submit') ✕