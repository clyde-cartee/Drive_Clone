extends layout

block content
  .dashboard
    header
      h1 📁 Drive Clone
      nav
        span Welcome, #{username} 
        a(href='/logout') Log Out

    .upload-section
      h2 Upload a File
      form(action='/upload', method='POST', enctype='multipart/form-data')
        input(type='file', name='file', id='fileInput', required)
        label(for='fileInput') Choose a file
        button(type='submit') Upload

    .files-section
      h2 Your Files
      if files.length === 0
        p No files uploaded yet.
      else
        table
          thead
            tr
              th Name
              th Type
              th Size
              th Uploaded
              th View
              th Download
              th Delete
          tbody
            each file in files
              tr
                td
                  a(href='/file/' + file.id, target='_blank')= file.originalName
                td= file.mimetype
                td= (file.size / 1024).toFixed(1) + ' KB'
                td= new Date(file.createdAt).toLocaleDateString()
                td
                  a(href='/file/' + file.id, target='_blank') 👁 View
                td
                  a(href='/download/' + file.id) ⬇ Download
                td
                  form(action='/delete/' + file.id, method='POST', onsubmit='return confirm("Delete this file?")')
                    button.delete-btn(type='submit') 🗑 Delete