extends layout

block content
  .dashboard
    header
      h1 📁 Drive Clone
      nav
        span Welcome, #{username} 
        a(href='/logout') Log Out

    .breadcrumb
      a(href='/dashboard') Home
      if currentFolder
        span  › 
        span= currentFolder.name

    .folder-section
      form(action='/folder/create' + (folderId ? '?folder=' + folderId : ''), method='POST')
        input(type='text', name='name', placeholder='New folder name', required)
        button(type='submit') + New Folder

    if !currentFolder && folders.length > 0
      .folders-grid
        each folder in folders
          a.folder-card(href='/dashboard?folder=' + folder.id)
            span.folder-icon 📁
            span= folder.name

    .upload-section
      h2 Upload a File
      form(action='/upload' + (folderId ? '?folder=' + folderId : ''), method='POST', enctype='multipart/form-data')
        input(type='file', name='file', id='fileInput', required)
        label(for='fileInput') Choose a file
        button(type='submit') Upload
    //- Files table
    .files-section
      h2= currentFolder ? currentFolder.name + ' Files' : 'Your Files'
      if files.length === 0
        p No files here yet.
      else
        table
          thead
            tr
              th Name
              th Type
              th Size
              th Uploaded
              th View
              th Download
              th Delete
          tbody
            each file in files
              tr
                td
                  a(href='/file/' + file.id, target='_blank')= file.originalName
                td= file.mimetype
                td= (file.size / 1024).toFixed(1) + ' KB'
                td= new Date(file.createdAt).toLocaleDateString()
                td
                  a(href='/file/' + file.id, target='_blank') 👁 View
                td
                  a(href='/download/' + file.id) ⬇ Download
                td
                  form(action='/delete/' + file.id, method='POST', onsubmit='return confirm("Delete this file?")')
                    button.delete-btn(type='submit') 🗑 Delete